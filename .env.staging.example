# ==========================================
# Supabase Edge Function Secrets (billing - staging)
# Set these in Supabase Dashboard → Project Settings → Edge Functions, NOT here.
# ==========================================
# LEMON_SQUEEZY_API_KEY=lemon_...
# LEMON_SQUEEZY_STORE_ID=12345
# LEMON_SQUEEZY_WEBHOOK_SECRET=whsec_...
# LEMON_SQUEEZY_VARIANT_PRO_MONTHLY=staging_variant_id
# LEMON_SQUEEZY_VARIANT_PRO_YEARLY=staging_variant_id
# LEMON_SQUEEZY_VARIANT_LIFETIME=staging_variant_id
# LEMON_SQUEEZY_VARIANT_DONATE=staging_variant_id
# LEMON_SQUEEZY_TEST_MODE=true
# BOT_API_KEY=<32-byte hex, must match bot .env.staging>
# SUPABASE_SERVICE_ROLE_KEY=<staging service role key>
# SUPABASE_URL=https://your-staging-project.supabase.co
