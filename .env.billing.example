# ============================================
# BILLING BACKEND - Environment Variables
# ============================================

# ============================================
# FRONTEND (.env in ton618-web root)
# ============================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ============================================
# SUPABASE EDGE FUNCTIONS
# Set in: Supabase Dashboard → Project Settings → Edge Functions
# ============================================

# Supabase (auto-configured)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key

# Discord OAuth2
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=https://your-project.supabase.co/auth/v1/callback

# Lemon Squeezy API
LEMON_SQUEEZY_API_KEY=lemon_your_api_key_here
LEMON_SQUEEZY_STORE_ID=12345
LEMON_SQUEEZY_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Lemon Squeezy Product Variant IDs
# Get these from Lemon Squeezy Dashboard → Products → [Your Product] → Variants
LEMON_SQUEEZY_VARIANT_PRO_MONTHLY=123456
LEMON_SQUEEZY_VARIANT_PRO_YEARLY=123457
LEMON_SQUEEZY_VARIANT_LIFETIME=123458
LEMON_SQUEEZY_VARIANT_DONATE=123459

# Test Mode (set to false in production)
LEMON_SQUEEZY_TEST_MODE=false

# Bot API Key (shared secret between Supabase and Bot)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Must be the same in bot .env
BOT_API_KEY=your_secure_random_key_min_32_chars

# ============================================
# BOT (.env in ton618-bot root)
# ============================================
SUPABASE_URL=https://your-project.supabase.co
BOT_API_KEY=your_secure_random_key_min_32_chars
# ^ Must match the BOT_API_KEY in Supabase Edge Functions
